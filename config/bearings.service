[Unit]
Description=Bearings — Claude Code agent web UI
After=network.target

[Service]
Type=simple
ExecStart=%h/.local/bin/bearings serve
Restart=on-failure
RestartSec=5

# --- Sandbox hardening (2026-04-21 security audit §4) -----------------
# User unit: most of these cost nothing because the app never needs
# kernel tunables, alternate personalities, or SUID binaries. Tuned to
# leave `$HOME` writable (Bearings reads ~/.claude and writes
# ~/.local/share/bearings + ~/.config/bearings) and to allow the
# `claude` CLI subprocess to spawn normally.
NoNewPrivileges=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectSystem=strict
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectProc=invisible
RestrictSUIDSGID=yes
RestrictRealtime=yes
RestrictNamespaces=yes
LockPersonality=yes
CapabilityBoundingSet=
AmbientCapabilities=
SystemCallArchitectures=native
# Soft caps — generous for chat + ring buffers, tight enough that a
# runaway loop doesn't eat the desktop. Tune in config.toml via
# systemd drop-in if your workflow genuinely needs more.
MemoryMax=2G
TasksMax=256

[Install]
WantedBy=default.target
